# myPiPOS Environment Variables Template
# Copy this file to .env.local for local development or set up in Vercel for production

# ============================================================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ============================================================================
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=your_neon_database_url_here

# ============================================================================
# PI NETWORK CONFIGURATION
# ============================================================================
# Pi Network API URL (use testnet for development)
PI_API_URL=https://api.testnet.minepi.com/v2
# Production: https://api.minepi.com/v2

# Pi Network API Key (required for server-side payment operations)
# Get your API key from: https://developers.minepi.com
PI_API_KEY=your-pi-api-key-here

# ============================================================================
# PI NETWORK WALLET CONFIGURATION
# ============================================================================
# Platform wallet address (for A2U payments and refunds)
# This is the sender address for platform-to-user payments
PI_WALLET_ADDRESS=your-pi-wallet-address-here

# Platform wallet private key/secret seed
# WARNING: Keep this secure! Never commit to version control
# Used for signing A2U payments and platform transactions
PI_WALLET_PRIVATE_KEY=your-wallet-private-key-here
# Alternative: Use seed phrase (spaces or comma-separated)
# PI_WALLET_SEED=word1 word2 word3 ... or word1,word2,word3,...

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Production URL: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# NEXTAUTH CONFIGURATION (if using authentication)
# ============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# PINATA IPFS CONFIGURATION
# ============================================================================
# Get JWT from https://app.pinata.cloud/developers/api-keys
# Server-side only (never exposed to client)
PINATA_JWT=your_pinata_jwt_token_here
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=development